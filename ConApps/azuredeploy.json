{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "[format('openwebui-{0}', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Container App の名前。https://<appName>.<region>.azurecontainerapps.io でアクセスできます。"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "デプロイ先リージョン"
      }
    },
    "storageAccountName": {
      "type": "string",
      "defaultValue": "[toLower(format('owui{0}', uniqueString(resourceGroup().id)))]",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "永続データ(/app/backend/data)用ストレージアカウント名。3〜24文字の小文字英数字のみで、Azure全体で一意である必要があります。"
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/open-webui/open-webui:main",
      "metadata": {
        "description": "デプロイするコンテナイメージ"
      }
    },
    "containerCpu": {
      "type": "string",
      "defaultValue": "1.0",
      "metadata": {
        "description": "コンテナに割り当てるvCPU数。RAG用の埋め込みモデルをロードするため最低1.0を推奨。containerMemoryと有効な組み合わせである必要があります。"
      }
    },
    "containerMemory": {
      "type": "string",
      "defaultValue": "2Gi",
      "metadata": {
        "description": "コンテナに割り当てるメモリ。containerCpuと有効な組み合わせである必要があります(例: 1.0vCPU=2Gi)。"
      }
    },
    "webuiSecretKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "セッション署名用のシークレットキー (WEBUI_SECRET_KEY)。空欄の場合、コンテナ側が /app/backend/data 内に自動生成して永続化するため、再デプロイしても値は変わりません。"
      }
    },
    "webuiAuth": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "ログイン認証を有効にするか (WEBUI_AUTH)"
      }
    },
    "enableSignup": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "新規ユーザーのサインアップを許可するか (ENABLE_SIGNUP)"
      }
    },
    "openAiApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "OpenAI互換API(Azure AI Foundryなど)のAPIキー (OPENAI_API_KEY)。空欄の場合はデプロイ後にOpen WebUIのAdmin Settings > Connectionsから設定できます。"
      }
    },
    "openAiApiBaseUrl": {
      "type": "string",
      "defaultValue": "https://api.openai.com/v1",
      "metadata": {
        "description": "OpenAI互換APIのベースURL (OPENAI_API_BASE_URL)。Azure AI Foundryを使う場合は https://<リソース名>.services.ai.azure.com/openai/v1 のようなエンドポイントを指定します。"
      }
    },
    "enableOllamaApi": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Ollama連携を有効にするか (ENABLE_OLLAMA_API)"
      }
    },
    "ollamaBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "外部Ollamaサーバーの URL (OLLAMA_BASE_URL)。使用しない場合は空欄のままにできます。"
      }
    }
  },
  "variables": {
    "logAnalyticsWorkspaceName": "[format('{0}-law', parameters('appName'))]",
    "envName": "[format('{0}-env', parameters('appName'))]",
    "fileShareName": "openwebui-data",
    "storageMountName": "openwebui-data",
    "dataMountPath": "/app/backend/data",
    "logAnalyticsWorkspaceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('logAnalyticsWorkspaceName'))]",
    "envId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
    "storageAccountId": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
    "fileShareId": "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', parameters('storageAccountName'), 'default', variables('fileShareName'))]",
    "envStorageId": "[resourceId('Microsoft.App/managedEnvironments/storages', variables('envName'), variables('storageMountName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-01-01",
      "name": "[format('{0}/default/{1}', parameters('storageAccountName'), variables('fileShareName'))]",
      "dependsOn": [ "[variables('storageAccountId')]" ]
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('logAnalyticsWorkspaceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "name": "PerGB2018" },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('envName')]",
      "location": "[parameters('location')]",
      "dependsOn": [ "[variables('logAnalyticsWorkspaceId')]" ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(variables('logAnalyticsWorkspaceId'), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(variables('logAnalyticsWorkspaceId'), '2022-10-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments/storages",
      "apiVersion": "2024-03-01",
      "name": "[format('{0}/{1}', variables('envName'), variables('storageMountName'))]",
      "dependsOn": [
        "[variables('envId')]",
        "[variables('fileShareId')]"
      ],
      "properties": {
        "azureFile": {
          "accountName": "[parameters('storageAccountName')]",
          "accountKey": "[listKeys(variables('storageAccountId'), '2023-01-01').keys[0].value]",
          "shareName": "[variables('fileShareName')]",
          "accessMode": "ReadWrite"
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[variables('envId')]",
        "[variables('envStorageId')]"
      ],
      "properties": {
        "managedEnvironmentId": "[variables('envId')]",
        "configuration": {
          "ingress": {
            "external": true,
            "targetPort": 8080,
            "transport": "auto",
            "allowInsecure": false
          }
        },
        "template": {
          "containers": [
            {
              "name": "open-webui",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[json(parameters('containerCpu'))]",
                "memory": "[parameters('containerMemory')]"
              },
              "env": [
                { "name": "WEBUI_SECRET_KEY", "value": "[parameters('webuiSecretKey')]" },
                { "name": "WEBUI_AUTH", "value": "[string(parameters('webuiAuth'))]" },
                { "name": "ENABLE_SIGNUP", "value": "[string(parameters('enableSignup'))]" },
                { "name": "OPENAI_API_KEY", "value": "[parameters('openAiApiKey')]" },
                { "name": "OPENAI_API_BASE_URL", "value": "[parameters('openAiApiBaseUrl')]" },
                { "name": "ENABLE_OLLAMA_API", "value": "[string(parameters('enableOllamaApi'))]" },
                { "name": "OLLAMA_BASE_URL", "value": "[parameters('ollamaBaseUrl')]" },
                { "name": "CORS_ALLOW_ORIGIN", "value": "*" },
                { "name": "FORWARDED_ALLOW_IPS", "value": "*" },
                { "name": "SCARF_NO_ANALYTICS", "value": "true" },
                { "name": "DO_NOT_TRACK", "value": "true" },
                { "name": "ANONYMIZED_TELEMETRY", "value": "false" }
              ],
              "volumeMounts": [
                { "volumeName": "openwebui-data", "mountPath": "[variables('dataMountPath')]" }
              ]
            }
          ],
          "volumes": [
            {
              "name": "openwebui-data",
              "storageType": "AzureFile",
              "storageName": "[variables('storageMountName')]"
            }
          ],
          "scale": {
            "minReplicas": 1,
            "maxReplicas": 1
          }
        }
      }
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "value": "[format('https://{0}', reference(resourceId('Microsoft.App/containerApps', parameters('appName'))).configuration.ingress.fqdn)]"
    }
  }
}
