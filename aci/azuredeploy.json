{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "containerGroupName": {
      "type": "string",
      "defaultValue": "[format('openwebui-aci-{0}', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "Container Instances のコンテナグループ名"
      }
    },
    "dnsNameLabel": {
      "type": "string",
      "defaultValue": "[format('openwebui-aci-{0}', uniqueString(resourceGroup().id))]",
      "metadata": {
        "description": "公開URL用のDNSラベル。http://<dnsNameLabel>.<region>.azurecontainer.io:8080 でアクセスします。リージョン内でグローバルに一意である必要があります。"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "デプロイ先リージョン"
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/open-webui/open-webui:main",
      "metadata": {
        "description": "デプロイするコンテナイメージ"
      }
    },
    "cpuCores": {
      "type": "int",
      "defaultValue": 1,
      "metadata": {
        "description": "コンテナに割り当てるvCPU数"
      }
    },
    "memoryInGB": {
      "type": "int",
      "defaultValue": 2,
      "metadata": {
        "description": "コンテナに割り当てるメモリ(GB)。RAG用の埋め込みモデルをロードするため最低2GBを推奨。"
      }
    },
    "restartPolicy": {
      "type": "string",
      "defaultValue": "Never",
      "allowedValues": [ "Always", "Never", "OnFailure" ],
      "metadata": {
        "description": "コンテナ終了時の再起動ポリシー。検証用途のためデフォルトはNever。"
      }
    },
    "webuiSecretKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "セッション署名用のシークレットキー (WEBUI_SECRET_KEY)。永続化していないため、コンテナ再作成のたびに実質使い捨てになります。"
      }
    },
    "webuiAuth": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "ログイン認証を有効にするか (WEBUI_AUTH)"
      }
    },
    "enableSignup": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "新規ユーザーのサインアップを許可するか (ENABLE_SIGNUP)"
      }
    },
    "openAiApiKey": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "OpenAI互換API(Azure AI Foundryなど)のAPIキー (OPENAI_API_KEY)。空欄の場合はデプロイ後にOpen WebUIのAdmin Settings > Connectionsから設定できます。"
      }
    },
    "openAiApiBaseUrl": {
      "type": "string",
      "defaultValue": "https://api.openai.com/v1",
      "metadata": {
        "description": "OpenAI互換APIのベースURL (OPENAI_API_BASE_URL)"
      }
    },
    "enableOllamaApi": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Ollama連携を有効にするか (ENABLE_OLLAMA_API)"
      }
    },
    "ollamaBaseUrl": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "外部Ollamaサーバーの URL (OLLAMA_BASE_URL)。使用しない場合は空欄のままにできます。"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.ContainerInstance/containerGroups",
      "apiVersion": "2023-05-01",
      "name": "[parameters('containerGroupName')]",
      "location": "[parameters('location')]",
      "properties": {
        "osType": "Linux",
        "restartPolicy": "[parameters('restartPolicy')]",
        "ipAddress": {
          "type": "Public",
          "dnsNameLabel": "[parameters('dnsNameLabel')]",
          "ports": [
            { "protocol": "Tcp", "port": 8080 }
          ]
        },
        "containers": [
          {
            "name": "open-webui",
            "properties": {
              "image": "[parameters('containerImage')]",
              "ports": [
                { "port": 8080, "protocol": "Tcp" }
              ],
              "resources": {
                "requests": {
                  "cpu": "[parameters('cpuCores')]",
                  "memoryInGB": "[parameters('memoryInGB')]"
                }
              },
              "environmentVariables": [
                { "name": "WEBUI_SECRET_KEY", "secureValue": "[parameters('webuiSecretKey')]" },
                { "name": "WEBUI_AUTH", "value": "[string(parameters('webuiAuth'))]" },
                { "name": "ENABLE_SIGNUP", "value": "[string(parameters('enableSignup'))]" },
                { "name": "OPENAI_API_KEY", "secureValue": "[parameters('openAiApiKey')]" },
                { "name": "OPENAI_API_BASE_URL", "value": "[parameters('openAiApiBaseUrl')]" },
                { "name": "ENABLE_OLLAMA_API", "value": "[string(parameters('enableOllamaApi'))]" },
                { "name": "OLLAMA_BASE_URL", "value": "[parameters('ollamaBaseUrl')]" },
                { "name": "CORS_ALLOW_ORIGIN", "value": "*" },
                { "name": "FORWARDED_ALLOW_IPS", "value": "*" },
                { "name": "SCARF_NO_ANALYTICS", "value": "true" },
                { "name": "DO_NOT_TRACK", "value": "true" },
                { "name": "ANONYMIZED_TELEMETRY", "value": "false" }
              ]
            }
          }
        ]
      }
    }
  ],
  "outputs": {
    "webUiUrl": {
      "type": "string",
      "value": "[format('http://{0}:8080', reference(resourceId('Microsoft.ContainerInstance/containerGroups', parameters('containerGroupName'))).ipAddress.fqdn)]"
    }
  }
}
